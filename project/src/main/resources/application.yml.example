# ==========================================
# 敏感配置文件模板（仅供参考结构）
# 请复制此文件为 application.yml 并填入真实配置
# ==========================================

# 应用配置
server:
  port: 5000
  servlet:
    context-path: /api

spring:
  mvc:
    static-path-pattern: /upload/**

  resources:
    static-locations: file:src/main/resources/static

  datasource:
    # ⚠️ 修改为你的数据库信息
    url: jdbc:mysql://127.0.0.1:3306/project_db?serverTimezone=GMT%2B8&useSSL=false&characterEncoding=utf-8
    username: root
    password: YOUR_DB_PASSWORD_HERE  # ⚠️ 修改为你的数据库密码
    driver-class-name: com.mysql.cj.jdbc.Driver
    type: com.alibaba.druid.pool.DruidDataSource

  jackson:
    property-naming-strategy: CAMEL_CASE_TO_LOWER_CASE_WITH_UNDERSCORES
    default-property-inclusion: ALWAYS
    time-zone: GMT+8
    date-format: yyyy-MM-dd HH:mm:ss

  servlet:
    multipart:
      max-file-size: 20480MB
      max-request-size: 20480MB

  redis:
    host: 127.0.0.1
    port: 6379
    password: YOUR_REDIS_PASSWORD_HERE  # ⚠️ 修改为你的 Redis 密码（如无密码留空）
    database: 2
    lettuce:
      pool:
        max-idle: 30
        min-idle: 10
        max-active: 30
        max-wait: 10000

  mail:
    host: smtp.qq.com
    port: 587
    username: YOUR_EMAIL@example.com  # ⚠️ 修改为你的邮箱
    password: YOUR_EMAIL_PASSWORD_HERE  # ⚠️ 修改为你的邮箱密码/授权码
    properties:
      mail:
        smtp:
          auth: true
          starttls:
            enable: true
          enable:
            trust: smtp.qq.com

mybatis-plus:
  mapper-locations: classpath*:mapper/*.xml
  type-aliases-package: com.project.demo.entity
  configuration:
    log-impl: org.apache.ibatis.logging.stdout.StdOutImpl
    use-column-label: true
    map-underscore-to-camel-case: false
    lazy-loading-enabled: true
    aggressive-lazy-loading: false
    use-generated-keys: true
